{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "paths": {
      "@gold/domain": ["../../packages/domain/src/index.ts"],
      "@gold/domain/*": ["../../packages/domain/src/*/index.ts"],
      "@gold/contracts": ["../../packages/contracts/src/index.ts"],
      "@gold/contracts/*": ["../../packages/contracts/src/*/index.ts"]
    }
  },
  "include": ["src"]
}
